# Rust build output
/target/
/core-ocr/target/

# Node / Vite
/app/node_modules/
/app/dist/
/app-img/node_modules/
/app-img/dist/
/app-zip/node_modules/
/app-zip/dist/
/app-img2pdf/node_modules/
/app-img2pdf/dist/
/app-scrub/node_modules/
/app-scrub/dist/
/app-ocr/node_modules/
/app-ocr/dist/

# Generated by wasm-pack (rebuilt by `make build` and CI)
/app/src/wasm/
/app-img/src/wasm/
/app-zip/src/wasm/
/app-img2pdf/src/wasm/
/app-ocr/src/wasm/*
!/app-ocr/src/wasm/.gitignore

# Misc
*.log
.DS_Store

# Staging test corpus (regenerated by scripts/build-corpus.sh; third-party/personal PDFs not committed)
/test-corpus/

# wrangler local state
.wrangler/

# image smoke corpus (generated, not committed to public repo)
img-corpus/
shots-img/

# archive smoke corpus (generated, not committed to public repo)
zip-corpus/
shots-zip/
# scrubber smoke corpus + venv (generated, not committed to public repo)
scrub-corpus/
shots-scrub/
.scrubvenv/

# images->PDF smoke corpus (generated)
img2pdf-corpus/
shots-img2pdf/

# OCR model weights (fetched at build/deploy time, never committed)
app-ocr/public/models/*.rten
